!docs/**/*.xlsx

# ── Python ──
__pycache__/
*.py[cod]
.venv-earmarking/

.ipynb_checkpoints/

# ── R ──
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

